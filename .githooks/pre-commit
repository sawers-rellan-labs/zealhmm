#!/usr/bin/env bash
#
# Auto-format staged R / Rmd / qmd files with styler (tidyverse style) before
# each commit, then re-stage whatever styler changed. Code chunks inside .qmd
# / .Rmd are styled in place; prose is left untouched.
#
# This hook is tracked in the repo. Activate it once per clone with:
#     git config core.hooksPath .githooks
#
set -euo pipefail

# staged Added/Copied/Modified R-family files (agent/ etc. are gitignored)
files=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.(R|r|Rmd|rmd|qmd)$' || true)
[ -z "$files" ] && exit 0

if ! command -v Rscript >/dev/null 2>&1; then
  echo "pre-commit: Rscript not found; skipping styler." >&2
  exit 0
fi

echo "pre-commit: styling R/Rmd/qmd with styler…"
printf '%s\n' "$files" | Rscript -e '
  files <- readLines("stdin")
  files <- files[nzchar(files) & file.exists(files)]
  if (!length(files)) quit(status = 0)
  if (!requireNamespace("styler", quietly = TRUE)) {
    message("pre-commit: styler not installed; skipping."); quit(status = 0)
  }
  invisible(lapply(files, styler::style_file))
'

# re-stage anything styler reformatted so the styled version is committed
printf '%s\n' "$files" | while IFS= read -r f; do
  [ -n "$f" ] && git add -- "$f"
done
