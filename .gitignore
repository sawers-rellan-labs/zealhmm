# Bulk inputs / generated outputs — not tracked (per project convention).
# Inputs live on the mount, referenced from DATA.md. sim/ holds generated
# simulations (the generator code is R/simulate.R, which IS tracked).
/data/
/results/
/sim/

# R session state
.RData
.Rhistory
.Rproj.user/
*.Rproj

# Claude Code local state
/.claude/

# agent/ — internal working area (plan, handoff prompts); not published
/agent

# nilhmm-paper/ — the manuscript is its OWN standalone git repo, nested here
# for convenience; zealhmm does not track it.
/nilhmm-paper/

# macOS
.DS_Store

# Quarto render artifacts: freeze/exec caches and stray per-figure _files dirs
# (embed-resources docs are self-contained and need no sidecar dir).
/.quarto/
/_freeze/
**/*.quarto_ipynb
*_cache/
*_files/

# stray R plot device output
Rplots.pdf
