# Untracked input data and generated results (per project convention).
# data/ holds only small inputs + manifests that ARE tracked (see below);
# large inputs live on the mount and are referenced from data/MANIFEST.md.
/data/*
!/data/MANIFEST.md
!/data/.gitkeep

# Derived tables/figures — regenerated by `quarto render` / sim scripts.
/results/*
!/results/.gitkeep

# R session state
.RData
.Rhistory
.Rproj.user/
*.Rproj

# Claude Code local state
/.claude/

# agent/ — internal working area (plan, handoff prompts); not published
/agent

# macOS
.DS_Store

# Quarto render artifacts: freeze/exec caches and stray per-figure _files dirs
# (embed-resources docs are self-contained and need no sidecar dir).
/.quarto/
**/*.quarto_ipynb
*_cache/
*_files/
